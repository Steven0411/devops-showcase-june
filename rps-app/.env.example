# Copy this file to ".env" and adjust if needed.

# Local MongoDB (default). The "rps" database is created automatically.
MONGODB_URI=mongodb://127.0.0.1:27017/rps

# Port the web server listens on.
PORT=3000

# --- Using MongoDB Atlas instead? Swap the URI for your cluster string: ---
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/rps
